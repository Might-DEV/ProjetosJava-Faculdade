// CLASSE COM A LOGICA DO FUNCIONAMENTO DO RELOGIO

import javax.swing.JLabel;
import javax.swing.SwingUtilities;
public class DadosRelogio {
//VARIAVEIS PRIVADAS 
	private int hora;
	private int min;
	private int seg = 0;

// CONSTRUTOR ONDE VC JA PODE INICIAR COM OS VALORES DA HORA E MIN, O SEGUNDO INICIA COM ZERO
	DadosRelogio(int hora, int min){
		this.hora = hora;
		this.min = min;
	}

	public void horaDinamica(JLabel lblHora) throws InterruptedException {

		while(this.hora != 61) {

			Thread.sleep(1000); // PARA DIMINUIR A VELOCIDADE, VAI PASSAR A POR SEGUNDO 

			String horaFormatada = String.format("%02d : %02d : %02d", this.hora, this.min, this.seg);
			System.out.println(horaFormatada);

			SwingUtilities.invokeLater(new Runnable() {
				public void run() {
					lblHora.setText(horaFormatada);
				}
			});

			this.seg++;

			if(this.seg == 60) {
				this.seg = 0;
				this.min++;
			}
			if(this.min == 60) {
				this.min = 0;
				this.hora++;
			}
			if(this.hora == 24) {
				this.hora = 0;
			}
		}
	}
}

