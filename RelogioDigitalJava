public class InterfaceRelogio extends JFrame {
	private static final long serialVersionUID = 1L;
	private JPanel contentPane;
	private JLabel lblHora;

	public static void main(String[] args) {
		EventQueue.invokeLater(new Runnable() {
			public void run() {
				try {
					InterfaceRelogio frame = new InterfaceRelogio();
					frame.setVisible(true);

					DadosRelogio r1 = new DadosRelogio(01, 16);

					Thread threadRelogio = new Thread(new Runnable() {
						public void run() {
							try {
								r1.horaDinamica(frame.lblHora);
							} catch (InterruptedException e) {
								e.printStackTrace();
							}
						}
					});
					threadRelogio.start();

				} catch (Exception e) {
					e.printStackTrace();
				}
			}
		});
	}

	public InterfaceRelogio() {
		setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
